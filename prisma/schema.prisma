generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Portfolio {
  id              String            @id @default(uuid())
  name            String
  trades          Trade[]
  dividends       Dividend[]
  snapshots       TaxYearSnapshot[]
  holdingSettings HoldingSettings[]
}

model Trade {
  id          String   @id @default(uuid())
  portfolioId String
  ticker      String
  tradeType   String // "BUY" or "SELL"
  tradeDate   DateTime
  quantity    Float
  price       Float // In native currency
  brokerage   Float // In native currency
  currency    String // e.g., USD, AUD
  fxRateToNzd Float // Cached Exchange rate on tradeDate
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model Dividend {
  id          String   @id @default(uuid())
  portfolioId String
  ticker      String
  date        DateTime
  grossAmount Float // In native currency
  taxWithheld Float // In native currency
  currency    String
  fxRateToNzd Float // Cached Exchange rate on dividend date
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model HoldingSettings {
  id             String  @id @default(uuid())
  portfolioId    String
  ticker         String
  isFifExempt    Boolean @default(false) // e.g., True for most ASX stocks
  yahooSymbol    String? // Override ticker for Yahoo Finance lookups (e.g. "CSPX.L")
  instrumentName String? // Human-readable name (e.g. "Apple Inc.")
  exchange       String? // Exchange identifier (e.g. "NZX", "NYSE", "LSE")
  portfolio      Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker])
}

model TaxYearSnapshot {
  id               String  @id @default(uuid())
  portfolioId      String
  taxYear          String // Format: "2023-2024" (April 1 to March 31)
  ticker           String
  openingQty       Float
  openingPrice     Float // April 1 native price
  openingFxRate    Float // April 1 FX rate to NZD
  closingQty       Float
  closingPrice     Float // March 31 native price
  closingFxRate    Float // March 31 FX rate to NZD
  isManuallyEdited Boolean @default(false) // True if user overrides API data
  portfolio        Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, taxYear, ticker])
}

model FxRateCache {
  date     DateTime
  currency String // e.g., USD
  rateNzd  Float // Value of 1 unit of currency in NZD

  @@id([date, currency])
}

model EodPriceCache {
  date   DateTime
  ticker String
  price  Float // In native currency

  @@id([date, ticker])
}

model AppliedSplit {
  id             String   @id @default(uuid())
  ticker         String
  splitDate      DateTime
  numerator      Float
  denominator    Float
  splitRatio     String // e.g., "10:1"
  appliedAt      DateTime @default(now())
  tradesAdjusted Int

  @@unique([ticker, splitDate])
}

model AppSetting {
  key   String @id
  value String
}

model SyncIssue {
  id         String    @id @default(uuid())
  ticker     String
  issueType  String // PRICE_MISSING | FX_RATE_MISSING | SYNC_FAILED | SPLIT_FETCH_FAILED
  message    String
  context    String? // JSON: { taxYear, date, currency, portfolioId }
  resolution String
  occurredAt DateTime  @default(now())
  resolvedAt DateTime?
}
